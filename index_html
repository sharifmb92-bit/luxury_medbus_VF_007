<!DOCTYPE html>
<html lang="es" x-data="appBus()">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MED BASHA PRO</title>
    <link rel="manifest" href="manifest.json">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('sw.js');
        });
      }
    </script>
    <link rel="manifest" href="data:application/json;base64,ewogICJuYW1lIjogIk1FRCBCQVN ">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/3448/3448339.png">
    <meta name="theme-color" content="#0f172a">

    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        [x-cloak] { display: none !important; }
        @keyframes amber-pulse {
            0%, 100% { background-color: rgba(245, 158, 11, 0.3); }
            50% { background-color: rgba(245, 158, 11, 1); box-shadow: 0 0 15px rgba(245, 158, 11, 0.6); }
        }
        .animate-amber { animation: amber-pulse 1.2s infinite; color: white !important; }
        .glass-card { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.1); }
        body { background-color: #0f172a; color: #f8fafc; font-family: system-ui, sans-serif; transition: all 0.3s ease; overflow-x: hidden; }
        input[type="time"]::-webkit-calendar-picker-indicator { filter: invert(1); }
        
        .input-dark { 
            background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; padding: 12px 8px; text-align: center; outline: none; width: 100%; color: white;
        }
        input[type="time"].input-dark { font-size: 1.6rem !important; font-weight: 900; }
        input[type="text"].input-dark { font-size: 1.3rem !important; font-weight: 800; color: #fbbf24; }
        input[type="number"].input-dark { font-size: 1.1rem !important; font-weight: 700; color: #22d3ee; }

        .lcd-clock { font-family: 'Courier New', Courier, monospace; letter-spacing: 2px; }
        .color-dot { width: 32px; height: 32px; border-radius: 50%; border: 2px solid transparent; }
        .color-dot.active { border-color: white; transform: scale(1.1); }
        
        /* Estilo para las cabeceras de semana */
        .semana-header { background: linear-gradient(90deg, rgba(59, 130, 246, 0.2), transparent); border-left: 4px solid #3b82f6; }
    </style>
</head>
<body :style="'font-size: ' + settings.fontSize + 'px;'">

    <div x-show="screen === 1" x-cloak class="p-4 max-w-md mx-auto pb-24">
        <header class="flex justify-between items-center mb-6">
            <div>
                <h1 class="text-2xl font-black italic tracking-tighter" :style="'color:' + settings.colorMaestro">MED BASHA PRO</h1>
                <p class="text-[10px] text-slate-500 uppercase font-black">Conductor Menorca</p>
            </div>
            <button @click="screen = 4; actualizarIconos()" class="p-2 bg-slate-800 rounded-full active:scale-90"><i data-lucide="settings"></i></button>
        </header>

        <div class="glass-card rounded-3xl p-4 mb-4 shadow-xl">
            <div class="flex justify-between items-center mb-4">
                <button @click="changeMonth(-1)" class="p-2"><i data-lucide="chevron-left"></i></button>
                <h2 class="font-bold text-lg" x-text="monthNames[currentMonth] + ' ' + currentYear"></h2>
                <button @click="changeMonth(1)" class="p-2"><i data-lucide="chevron-right"></i></button>
            </div>
            <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-black text-slate-500 mb-2">
                <span>LU</span><span>MA</span><span>MI</span><span>JU</span><span>VI</span><span>SA</span><span>DO</span>
            </div>
            <div class="grid grid-cols-7 gap-1 text-center">
                <template x-for="day in daysInMonth">
                    <button @click="day.num ? seleccionarDia(day.num) : null" 
                         class="h-10 flex flex-col items-center justify-center rounded-xl relative transition-all active:scale-90" 
                         :class="day.isToday ? 'bg-blue-600 font-bold shadow-lg shadow-blue-900/50' : (day.num ? 'hover:bg-white/5' : '')">
                        <span x-text="day.num"></span>
                        <div class="flex gap-0.5 mt-0.5" x-show="tieneRegistro(day.num)">
                            <div :class="obtenerTipoRegistro(day.num) === 'partida' ? 'bg-orange-500' : 'bg-blue-400'" class="w-1.5 h-1.5 rounded-full"></div>
                        </div>
                    </button>
                </template>
            </div>
        </div>

        <div @click="abrirAlarma()" class="glass-card rounded-2xl p-3 mb-6 flex items-center justify-center border-t-2 border-t-white/10 shadow-inner cursor-pointer active:scale-95 transition">
            <div class="flex flex-col items-center">
                <span class="text-[8px] font-black text-slate-500 uppercase tracking-[0.2em] mb-1">Reloj de a bordo</span>
                <div class="text-3xl font-black lcd-clock text-white" x-text="timeNow">00:00:00</div>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <button @click="openRegistro('continua')" class="glass-card p-6 rounded-3xl flex flex-col items-center gap-3 border-b-4 border-blue-500 active:scale-95 transition">
                <i data-lucide="timer" class="text-blue-500 w-8 h-8"></i>
                <span class="font-black uppercase text-xs">Continua</span>
            </button>
            <button @click="openRegistro('partida')" class="glass-card p-6 rounded-3xl flex flex-col items-center gap-3 border-b-4 border-orange-500 active:scale-95 transition">
                <i data-lucide="split" class="text-orange-500 w-8 h-8"></i>
                <span class="font-black uppercase text-xs">Partida</span>
            </button>
        </div>

        <button @click="screen = 3; calcularTotales(); actualizarIconos()" class="w-full mt-6 glass-card p-5 rounded-2xl flex justify-between items-center active:bg-white/5">
            <span class="font-bold text-sm uppercase italic">Resumen Nómina (Ciclo 16-15)</span>
            <i data-lucide="chevron-right" class="w-5 h-5 text-slate-600"></i>
        </button>
    </div>

    <div x-show="screen === 2" x-cloak class="p-4 max-w-md mx-auto pb-44">
        <header class="flex items-center gap-4 mb-6">
            <button @click="volverAlInicio()" class="p-2 bg-slate-800 rounded-full"><i data-lucide="arrow-left"></i></button>
            <div class="flex-1">
                <h2 class="text-xl font-black uppercase tracking-tighter" x-text="form.esPartida ? 'Jornada Partida' : 'Jornada Continua'"></h2>
                <p class="text-[10px] text-blue-400 font-bold" x-text="'Fecha: ' + fechaSeleccionada"></p>
            </div>
            <button x-show="!form.esPartida" @click="form.esPartida = true; calcular();" class="bg-orange-600 text-white p-2 rounded-full shadow-lg active:scale-75">
                <i data-lucide="plus" class="w-5 h-5"></i>
            </button>
        </header>

        <div class="space-y-4">
            <div class="glass-card p-4 rounded-3xl border-l-4 border-blue-500">
                <div class="flex justify-between items-center mb-3">
                    <span class="text-[10px] font-black text-blue-400 uppercase">Bus Mañana</span>
                    <input type="text" x-model="form.bus1" @input="guardarBorrador()" placeholder="BUS 1" class="w-24 input-dark uppercase">
                </div>
                <div class="grid grid-cols-2 gap-2 mb-3">
                    <input type="time" x-model="form.hE1" @change="calcular(); guardarBorrador()" class="input-dark">
                    <input type="time" x-model="form.hS1" @change="calcular(); guardarBorrador()" class="input-dark">
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <input type="number" x-model="form.kmI1" @input="calcular(); guardarBorrador()" placeholder="KM Ini" class="input-dark">
                    <input type="number" x-model="form.kmF1" @input="calcular(); guardarBorrador()" placeholder="KM Fin" class="input-dark">
                </div>
                <div class="flex justify-center mt-3">
                    <button @click="ponerHoraActual('hE1')" class="text-[9px] bg-blue-900/50 px-4 py-2 rounded-full border border-blue-500/30 font-black uppercase">Fichar Entrada</button>
                </div>
            </div>

            <div x-show="form.esPartida" x-transition class="glass-card p-4 rounded-3xl border-l-4 border-orange-500">
                <div class="flex justify-between items-center mb-3">
                    <span class="text-[10px] font-black text-orange-400 uppercase">Bus Tarde</span>
                    <input type="text" x-model="form.bus2" @input="guardarBorrador()" placeholder="BUS 2" class="w-24 input-dark uppercase">
                </div>
                <div class="grid grid-cols-2 gap-2 mb-3">
                    <input type="time" x-model="form.hE2" @change="calcular(); guardarBorrador()" class="input-dark">
                    <input type="time" x-model="form.hS2" @change="calcular(); guardarBorrador()" class="input-dark">
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <input type="number" x-model="form.kmI2" @input="calcular(); guardarBorrador()" placeholder="KM Ini" class="input-dark">
                    <input type="number" x-model="form.kmF2" @input="calcular(); guardarBorrador()" placeholder="KM Fin" class="input-dark">
                </div>
            </div>

            <div class="grid grid-cols-3 gap-2 mt-6">
                <button @click="form.comida = !form.comida; guardarBorrador()" 
                        :class="form.comida ? 'bg-green-600' : (alertaComida ? 'animate-amber' : 'bg-slate-800 opacity-40')" 
                        class="p-4 rounded-2xl flex flex-col items-center gap-1 font-black transition-all">
                    <i data-lucide="utensils" class="w-4 h-4"></i><span class="text-[9px] uppercase">Comida</span>
                </button>
                <button @click="form.cena = !form.cena; guardarBorrador()" 
                        :class="form.cena ? 'bg-green-600' : (alertaCena ? 'animate-amber' : 'bg-slate-800 opacity-40')" 
                        class="p-4 rounded-2xl flex flex-col items-center gap-1 font-black transition-all">
                    <i data-lucide="moon" class="w-4 h-4"></i><span class="text-[9px] uppercase">Cena</span>
                </button>
                <button @click="form.festivo = !form.festivo; guardarBorrador()" 
                        :class="form.festivo ? 'bg-red-600' : 'bg-slate-800 opacity-40'" 
                        class="p-4 rounded-2xl flex flex-col items-center gap-1 font-black transition-all">
                    <i data-lucide="calendar-heart" class="w-4 h-4"></i><span class="text-[9px] uppercase">Festivo</span>
                </button>
            </div>
        </div>

        <div class="fixed bottom-0 left-0 w-full glass-card border-t border-white/10 p-6 z-50">
            <div class="flex justify-between items-center max-w-md mx-auto">
                <div class="text-center">
                    <p class="text-[9px] text-slate-500 font-black mb-1 uppercase">H. Total</p>
                    <span class="text-3xl font-black text-green-400" x-text="res.hTotal">06:00</span>
                </div>
                <div class="text-center">
                    <p class="text-[9px] text-slate-500 font-black mb-1 uppercase">KM Totales</p>
                    <span class="text-3xl font-black text-cyan-400" x-text="res.kmTotal">0</span>
                </div>
                <button @click="guardarJornada()" :style="'background-color:' + settings.colorMaestro" class="text-white p-5 rounded-full shadow-2xl active:scale-75"><i data-lucide="save" class="w-7 h-7"></i></button>
            </div>
        </div>
    </div>

    <div x-show="screen === 3" x-cloak class="p-4 max-w-md mx-auto pb-32">
        <header class="flex justify-between items-center mb-6">
            <button @click="screen = 1" class="p-2 bg-slate-800 rounded-full"><i data-lucide="arrow-left"></i></button>
            <h2 class="text-xl font-black uppercase tracking-tighter italic">Historial Ciclo</h2>
        </header>

        <div class="mb-6 px-2">
            <span class="text-[14px] font-black text-white uppercase bg-blue-600 px-4 py-2 rounded-t-xl block w-fit" x-text="cicloLabel"></span>
            <div class="glass-card p-4 rounded-b-2xl rounded-tr-2xl grid grid-cols-2 gap-4 border-t-2 border-blue-600">
                <div><span class="text-[8px] text-slate-500 font-black uppercase">Total Ciclo</span><p class="text-xl font-black text-blue-400" x-text="stats.hTotales"></p></div>
                <div class="text-right"><span class="text-[8px] text-slate-500 font-black uppercase">KM Ciclo</span><p class="text-xl font-black text-cyan-400" x-text="stats.kmTotales"></p></div>
            </div>
        </div>

        <div class="space-y-8">
            <template x-for="(semana, index) in semanasAgrupadas" :key="index">
                <div class="space-y-2">
                    <div class="semana-header p-3 rounded-xl flex justify-between items-center">
                        <div>
                            <span class="block text-[10px] font-black text-blue-400 uppercase">Semana del Ciclo</span>
                            <span class="text-xs font-bold text-white" x-text="semana.rango"></span>
                        </div>
                        <div class="text-right">
                            <span class="block text-[9px] font-black text-slate-500 uppercase" x-text="semana.totalHoras + ' | ' + semana.totalKm + ' KM'"></span>
                            <button @click="enviarSemanaAGoogle(semana.registros)" class="text-[9px] bg-green-600 text-white px-3 py-1 rounded-full font-black mt-1 uppercase flex items-center gap-1">
                                <i data-lucide="cloud-upload" class="w-3 h-3"></i> Subir
                            </button>
                        </div>
                    </div>

                    <div class="glass-card rounded-2xl overflow-hidden border border-white/5">
                        <table class="w-full text-center">
                            <thead class="bg-black/20 text-[7px] text-slate-500 uppercase">
                                <tr><th class="p-3 text-left">Día</th><th>Bus</th><th>H.</th><th>D.</th><th>F.</th><th>P.</th><th></th></tr>
                            </thead>
                            <tbody class="text-[9px] font-bold divide-y divide-white/5">
                                <template x-for="item in semana.registros" :key="item.id">
                                    <tr>
                                        <td class="p-3 text-left flex items-center gap-2" @click="cargarRegistro(item)">
                                            <div :class="item.esPartida ? 'bg-orange-500' : 'bg-blue-400'" class="w-1.5 h-1.5 rounded-full shrink-0"></div>
                                            <span x-text="item.fecha"></span>
                                        </td>
                                        <td x-text="item.bus"></td>
                                        <td x-text="item.horas"></td>
                                        <td x-text="item.dietas" class="text-green-400"></td>
                                        <td x-text="item.esFestivo ? '1' : '-'" class="text-red-400"></td>
                                        <td x-text="item.esPartida ? '1' : '-'" class="text-orange-400"></td>
                                        <td class="p-1"><button @click="borrarRegistro(item.id)" class="text-red-500/20 p-2"><i data-lucide="trash-2" class="w-3 h-3"></i></button></td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>
                </div>
            </template>
        </div>
    </div>

    <div x-show="screen === 4" x-cloak class="p-4 max-w-md mx-auto pb-24">
        <header class="flex items-center gap-4 mb-8">
            <button @click="screen = 1" class="p-2 bg-slate-800 rounded-full"><i data-lucide="arrow-left"></i></button>
            <h2 class="text-xl font-black uppercase tracking-tighter">Configuración</h2>
        </header>

        <div class="space-y-6">
            <div class="grid grid-cols-2 gap-3">
                <button @click="abrirCalculadora()" class="glass-card p-4 rounded-3xl flex flex-col items-center gap-2 border-b-4 border-yellow-500 active:scale-95 transition">
                    <i data-lucide="calculator" class="text-yellow-500 w-6 h-6"></i>
                    <span class="font-black uppercase text-[10px]">Calculadora</span>
                </button>
                <button @click="abrirGoogleDrive()" class="glass-card p-4 rounded-3xl flex flex-col items-center gap-2 border-b-4 border-green-500 active:scale-95 transition">
                    <i data-lucide="file-text" class="text-green-500 w-6 h-6"></i>
                    <span class="font-black uppercase text-[10px]">Mi Google</span>
                </button>
            </div>

            <button @click="gestionarArchivos()" class="w-full glass-card p-5 rounded-3xl flex items-center justify-between border-l-4 border-indigo-500 active:scale-95 transition">
                <div class="flex items-center gap-3">
                    <i data-lucide="database" class="text-indigo-400"></i>
                    <div class="text-left">
                        <span class="block text-[10px] font-black uppercase">Gestor de Archivos</span>
                        <span class="text-[8px] text-slate-500 italic">Limpieza automática 6 meses</span>
                    </div>
                </div>
                <i data-lucide="chevron-right" class="text-slate-600"></i>
            </button>

            <div class="glass-card p-5 rounded-3xl border-l-4 border-green-500">
                <label class="text-[10px] font-black text-green-500 uppercase block mb-3">Google Sheets API URL</label>
                <input type="text" x-model="settings.sheetUrl" @change="saveSett()" class="bg-slate-900 border border-white/10 p-4 rounded-xl font-mono text-[9px] w-full text-slate-300">
            </div>

            <div class="glass-card p-5 rounded-3xl">
                <label class="text-[10px] font-black text-slate-500 block mb-4 uppercase">Tamaño Texto</label>
                <input type="range" x-model="settings.fontSize" @input="saveSett()" min="12" max="22" class="w-full h-1.5 bg-slate-700 rounded-lg accent-blue-500">
            </div>

            <div class="glass-card p-5 rounded-3xl">
                <label class="text-[10px] font-black text-slate-500 block mb-5 uppercase">Color Maestro</label>
                <div class="flex justify-between px-2">
                    <template x-for="color in palette">
                        <button @click="settings.colorMaestro = color; saveSett()" class="color-dot" :style="'background-color:' + color" :class="settings.colorMaestro === color ? 'active' : ''"></button>
                    </template>
                </div>
            </div>
            
            <button @click="if(confirm('¿Borrar todo?')) { historial = []; saveHist(); calcularTotales(); }" class="w-full p-4 text-[10px] font-black uppercase text-red-500 opacity-50">Resetear Datos Completos</button>
        </div>
    </div>

    <script>
        function appBus() {
            return {
                screen: 1, currentMonth: new Date().getMonth(), currentYear: new Date().getFullYear(),
                monthNames: ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"],
                daysInMonth: [], fechaSeleccionada: '', timeNow: '00:00:00', cicloLabel: '',
                palette: ['#71717a', '#3b82f6', '#f59e0b', '#10b981', '#ef4444'],
                settings: { fontSize: 16, colorMaestro: '#71717a', sheetUrl: '' },
                form: { id: null, esPartida: false, bus1: '', hE1: '', hS1: '', kmI1: '', kmF1: '', bus2: '', hE2: '', hS2: '', kmI2: '', kmF2: '', comida: false, cena: false, festivo: false },
                res: { hTotal: '06:00', kmTotal: 0 },
                historial: [], semanasAgrupadas: [],
                stats: { hTotales: '0:00', numPartidas: 0, numDietas: 0, numFestivos: 0, kmTotales: 0 },
                alertaComida: false, alertaCena: false,

                init() {
                    this.historial = JSON.parse(localStorage.getItem('bus_historial') || '[]');
                    this.settings = JSON.parse(localStorage.getItem('bus_settings') || JSON.stringify(this.settings));
                    
                    const borrador = JSON.parse(localStorage.getItem('bus_borrador_seguridad'));
                    if (borrador) { this.form = borrador; this.fechaSeleccionada = borrador.fechaBorrador || ''; this.calcular(); }

                    this.renderCalendar();
                    this.updateClock();
                    this.calcularTotales();
                    setInterval(() => this.updateClock(), 1000);
                    this.actualizarIconos();
                },

                guardarBorrador() {
                    const copia = JSON.parse(JSON.stringify(this.form));
                    copia.fechaBorrador = this.fechaSeleccionada;
                    localStorage.setItem('bus_borrador_seguridad', JSON.stringify(copia));
                },

                updateClock() { this.timeNow = new Date().toLocaleTimeString('es-ES', { hour12: false }); },
                
                renderCalendar() {
                    let first = new Date(this.currentYear, this.currentMonth, 1).getDay();
                    let days = new Date(this.currentYear, this.currentMonth + 1, 0).getDate();
                    first = (first === 0) ? 6 : first - 1;
                    this.daysInMonth = [];
                    for (let i = 0; i < first; i++) this.daysInMonth.push({ num: null });
                    for (let i = 1; i <= days; i++) {
                        this.daysInMonth.push({ num: i, isToday: new Date().toDateString() === new Date(this.currentYear, this.currentMonth, i).toDateString() });
                    }
                },

                formatearFecha(dia) { return `${dia.toString().padStart(2,'0')}/${(this.currentMonth + 1).toString().padStart(2,'0')}`; },
                tieneRegistro(dia) { return this.historial.some(h => h.fecha === this.formatearFecha(dia)); },
                obtenerTipoRegistro(dia) { return (this.historial.find(h => h.fecha === this.formatearFecha(dia))?.esPartida) ? 'partida' : 'continua'; },

                seleccionarDia(dia) {
                    const f = this.formatearFecha(dia);
                    const r = this.historial.find(h => h.fecha === f);
                    this.fechaSeleccionada = f;
                    if(r) this.cargarRegistro(r); else this.openRegistro('continua');
                },

                openRegistro(t) {
                    this.form = { id: Date.now(), esPartida: (t === 'partida'), bus1: '', hE1: '', hS1: '', kmI1: '', kmF1: '', bus2: '', hE2: '', hS2: '', kmI2: '', kmF2: '', comida: false, cena: false, festivo: false };
                    this.screen = 2;
                    this.calcular();
                    this.actualizarIconos();
                },

                cargarRegistro(item) {
                    this.form = JSON.parse(JSON.stringify(item.datos));
                    this.fechaSeleccionada = item.fecha;
                    this.screen = 2;
                    this.calcular();
                    this.actualizarIconos();
                },

                ponerHoraActual(campo) {
                    const ahora = new Date();
                    this.form[campo] = `${String(ahora.getHours()).padStart(2, '0')}:${String(ahora.getMinutes()).padStart(2, '0')}`;
                    this.calcular();
                    this.guardarBorrador();
                },

                calcular() {
                    const toM = (t) => { if(!t) return null; let [h,m] = t.split(':').map(Number); return h*60+m; };
                    let e1 = toM(this.form.hE1), s1 = toM(this.form.hS1);
                    let e2 = toM(this.form.hE2), s2 = toM(this.form.hS2);
                    let m1 = (s1 && e1) ? (s1 < e1 ? (s1+1440) - e1 : s1 - e1) : 0;
                    let m2 = (this.form.esPartida && s2 && e2) ? (s2 < e2 ? (s2+1440) - e2 : s2 - e2) : 0;
                    let realMins = m1 + m2;
                    let totalMins = (realMins > 0) ? (realMins < 360 ? 360 : realMins) : 360;
                    this.res.hTotal = `${Math.floor(totalMins/60).toString().padStart(2,'0')}:${(totalMins%60).toString().padStart(2,'0')}`;
                    this.res.kmTotal = ((parseInt(this.form.kmF1) - parseInt(this.form.kmI1)) || 0) + ((parseInt(this.form.kmF2) - parseInt(this.form.kmI2)) || 0);
                    const salidaFinal = this.form.esPartida ? s2 : s1;
                    this.alertaComida = (realMins >= 540 && s1 >= 900) || (realMins >= 360 && s1 >= 930);
                    this.alertaCena = (realMins >= 360 && salidaFinal >= 1380);
                },

                guardarJornada() {
                    if(!this.form.bus1) { alert("¡Falta número de BUS!"); return; }
                    const reg = {
                        id: this.form.id, fecha: this.fechaSeleccionada,
                        bus: this.form.esPartida ? `${this.form.bus1}/${this.form.bus2||'?'}` : this.form.bus1,
                        horas: this.res.hTotal, esPartida: this.form.esPartida, esFestivo: this.form.festivo,
                        dietas: (this.form.comida?1:0) + (this.form.cena?1:0),
                        km: this.res.kmTotal, datos: JSON.parse(JSON.stringify(this.form))
                    };
                    const idx = this.historial.findIndex(h => h.fecha === this.fechaSeleccionada);
                    if(idx > -1) this.historial[idx] = reg; else this.historial.unshift(reg);
                    this.saveHist(); this.calcularTotales();
                    localStorage.removeItem('bus_borrador_seguridad');
                    this.screen = 1; this.actualizarIconos();
                },

                // LÓGICA DE BLOQUES SEMANALES
                getWeekNumber(d) {
                    d = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
                    d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay() || 7));
                    var yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
                    return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
                },

                calcularTotales() {
                    const hoy = new Date();
                    const d = hoy.getDate();
                    const m = hoy.getMonth();
                    const y = hoy.getFullYear();

                    let inicio, fin;
                    if (d >= 16) { inicio = new Date(y, m, 16); fin = new Date(y, m + 1, 15); } 
                    else { inicio = new Date(y, m - 1, 16); fin = new Date(y, m, 15); }

                    this.cicloLabel = `Ciclo: 16/${inicio.getMonth()+1} al 15/${fin.getMonth()+1}`;

                    let filtrados = this.historial.filter(h => {
                        const [diaReg, mesReg] = h.fecha.split('/').map(Number);
                        let añoReg = y;
                        if (mesReg === 12 && inicio.getMonth() === 11) añoReg = inicio.getFullYear();
                        if (mesReg === 1 && fin.getMonth() === 0) añoReg = fin.getFullYear();
                        const fReg = new Date(añoReg, mesReg - 1, diaReg);
                        return fReg >= inicio && fReg <= fin;
                    }).sort((a,b) => b.id - a.id);

                    // Agrupar por semanas
                    const grupos = {};
                    filtrados.forEach(h => {
                        const [dia, mes] = h.fecha.split('/').map(Number);
                        const fechaObj = new Date(y, mes - 1, dia);
                        const numSemana = this.getWeekNumber(fechaObj);
                        
                        if (!grupos[numSemana]) {
                            grupos[numSemana] = { registros: [], totalHorasMins: 0, totalKm: 0, rango: '' };
                        }
                        grupos[numSemana].registros.push(h);
                        let [hh, mm] = h.horas.split(':').map(Number);
                        grupos[numSemana].totalHorasMins += (hh * 60 + mm);
                        grupos[numSemana].totalKm += h.km;
                    });

                    this.semanasAgrupadas = Object.keys(grupos).map(key => {
                        const g = grupos[key];
                        // Calcular rango de la semana para el título
                        const regs = g.registros;
                        g.rango = `Semana ${key}`;
                        g.totalHoras = `${Math.floor(g.totalHorasMins/60)}:${(g.totalHorasMins%60).toString().padStart(2,'0')}`;
                        return g;
                    }).sort((a, b) => b.registros[0].id - a.registros[0].id);

                    // Stats totales del ciclo
                    let mt = 0, kt = 0;
                    filtrados.forEach(h => {
                        let [hh,mm] = h.horas.split(':').map(Number); mt += (hh*60+mm); kt += h.km;
                    });
                    this.stats = { hTotales: `${Math.floor(mt/60)}:${(mt%60).toString().padStart(2,'0')}`, kmTotales: kt + ' KM' };
                },

                // FUNCIÓN DE ENVÍO CON EL ORDEN DE TUS COLUMNAS
                enviarSemanaAGoogle(registros) {
                    const dataParaEnviar = registros.map(r => {
                        // Cálculo nocturna simple (si termina después de las 22:00)
                        const horaSalida = r.datos.esPartida ? r.datos.hS2 : r.datos.hS1;
                        const esNocturna = (horaSalida && parseInt(horaSalida.split(':')[0]) >= 22) ? 'SÍ' : 'NO';

                        return {
                            fecha: r.fecha,          // 1. Fecha
                            bus: r.bus,              // 2. Bus
                            hora: r.horas,           // 3. Hora
                            dieta: r.dietas,         // 4. Dieta
                            nocturna: esNocturna,    // 5. Nocturna
                            kilometros: r.km,        // 6. Kilómetros
                            plusPartido: r.esPartida ? 'SÍ' : 'NO' // 7. Plus Partido
                        };
                    });

                    console.log("Enviando al Sheets:", dataParaEnviar);
                    alert(`Enviando ${registros.length} registros al orden:\nFecha | Bus | Hora | Dieta | Nocturna | KM | Plus`);
                    
                    // Aquí iría tu fetch(this.settings.sheetUrl, { method: 'POST', body: JSON.stringify(dataParaEnviar) });
                },

                gestionarArchivos() { if(confirm(`¿Limpiar registros de más de 6 meses?`)) this.limpiezaAutomatica(true); },
                limpiezaAutomatica(manual = false) {
                    const seisMesesAtras = Date.now() - (180 * 24 * 60 * 60 * 1000);
                    this.historial = this.historial.filter(h => h.id > seisMesesAtras);
                    this.saveHist(); this.calcularTotales();
                },
                borrarRegistro(id) { if(confirm('¿Borrar?')) { this.historial = this.historial.filter(h => h.id !== id); this.saveHist(); this.calcularTotales(); } },
                saveHist() { localStorage.setItem('bus_historial', JSON.stringify(this.historial)); },
                saveSett() { localStorage.setItem('bus_settings', JSON.stringify(this.settings)); },
                volverAlInicio() { this.screen = 1; this.actualizarIconos(); },
                changeMonth(s) { this.currentMonth += s; if(this.currentMonth>11){this.currentMonth=0;this.currentYear++}else if(this.currentMonth<0){this.currentMonth=11;this.currentYear--} this.renderCalendar(); },
                abrirAlarma() { window.location.href = "intent://com.android.deskclock/#Intent;scheme=android-app;end"; },
                abrirCalculadora() { window.open('https://www.google.com/search?q=calculadora', '_blank'); },
                abrirGoogleDrive() { window.open('https://drive.google.com', '_blank'); },
                actualizarIconos() { this.$nextTick(() => lucide.createIcons()); }
            }
        }
    </script>
